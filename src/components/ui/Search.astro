---
const htbPosts = await Astro.glob("../../pages/blog/posts/hackthebox/Machines/*.md");
const s10Posts = await Astro.glob("../../pages/blog/posts/hackthebox/season10/*.md");
const pgPosts = await Astro.glob("../../pages/blog/posts/provinggrounds/*.md");
const blogPosts = await Astro.glob("../../pages/blog/posts/Blogger/*.md");

const allPosts = [...htbPosts, ...s10Posts, ...pgPosts, ...blogPosts].map(post => ({
  title: post.frontmatter.title,
  url: post.url,
  tags: post.frontmatter.tags ?? [],
  languages: post.frontmatter.languages ?? [],
  date: post.frontmatter.pubDate,
}));
---

<!-- Search Icon Button -->
<button
  id="search-open"
  aria-label="Open search"
  class="flex items-center justify-center transition-all hover:text-mint-300"
>
  <svg width="18" height="18" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M10 6.5C10 8.433 8.433 10 6.5 10C4.567 10 3 8.433 3 6.5C3 4.567 4.567 3 6.5 3C8.433 3 10 4.567 10 6.5ZM9.30884 10.0159C8.53901 10.6318 7.56251 11 6.5 11C4.01472 11 2 8.98528 2 6.5C2 4.01472 4.01472 2 6.5 2C8.98528 2 11 4.01472 11 6.5C11 7.56251 10.6318 8.53901 10.0159 9.30884L12.8536 12.1464C13.0488 12.3417 13.0488 12.6583 12.8536 12.8536C12.6583 13.0488 12.3417 13.0488 12.1464 12.8536L9.30884 10.0159Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
  </svg>
</button>

<!-- Modal Overlay -->
<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden bg-black/60 backdrop-blur-sm"
>
  <div class="flex flex-col items-center w-full pt-16 max-sm:pt-14 px-4">
    <div class="w-full max-w-xl flex flex-col gap-3">

      <!-- Input -->
      <div class="relative">
        <input
          id="search-input"
          type="text"
          placeholder="Search posts, machines, tags..."
          class="w-full px-5 py-4 max-sm:py-3 pr-12 rounded-2xl border border-mint-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-blacktext dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-mint-400 transition-all text-base max-sm:text-sm"
        />
        <button
          id="search-close"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-all"
          aria-label="Close search"
        >
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.7816 4.03157C12.0062 3.80702 12.0062 3.44295 11.7816 3.2184C11.5571 2.99385 11.193 2.99385 10.9685 3.2184L7.50005 6.68682L4.03164 3.2184C3.80708 2.99385 3.44301 2.99385 3.21846 3.2184C2.99391 3.44295 2.99391 3.80702 3.21846 4.03157L6.68688 7.49999L3.21846 10.9684C2.99391 11.193 2.99391 11.557 3.21846 11.7816C3.44301 12.0061 3.80708 12.0061 4.03164 11.7816L7.50005 8.31316L10.9685 11.7816C11.193 12.0061 11.5571 12.0061 11.7816 11.7816C12.0062 11.557 12.0062 11.193 11.7816 10.9684L8.31322 7.49999L11.7816 4.03157Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>

      <!-- Results -->
      <ul id="search-results" class="flex flex-col gap-2 max-h-[60vh] max-sm:max-h-[70vh] overflow-y-auto"></ul>

    </div>
  </div>
</div>

<script define:vars={{ allPosts }}>
  const openBtn = document.getElementById('search-open');
  const closeBtn = document.getElementById('search-close');
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const searchBox = document.getElementById('search-modal').querySelector('.w-full.max-w-xl');

  function openModal() {
    modal.classList.remove('hidden');
    setTimeout(() => input.focus(), 50);
  }

  function closeModal() {
    modal.classList.add('hidden');
    input.value = '';
    results.innerHTML = '';
  }

  openBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    openModal();
  });

  closeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  document.addEventListener('click', (e) => {
    if (modal.classList.contains('hidden')) return;
    if (!searchBox.contains(e.target)) closeModal();
  });

  document.addEventListener('touchstart', (e) => {
    if (modal.classList.contains('hidden')) return;
    if (!searchBox.contains(e.target)) closeModal();
  }, { passive: true });

  window.addEventListener('scroll', (e) => {
    if (modal.classList.contains('hidden')) return;
    if (!results.contains(e.target)) closeModal();
  }, { passive: true, capture: true });

  results.addEventListener('scroll', (e) => {
    e.stopPropagation();
  }, { passive: true });

  results.addEventListener('touchmove', (e) => {
    e.stopPropagation();
  }, { passive: true });


  input.addEventListener('input', () => {
    const query = input.value.toLowerCase().trim();
    results.innerHTML = '';

    if (!query) return;

    const filtered = allPosts.filter(post =>
      post.title?.toLowerCase().includes(query) ||
      post.tags?.some(t => t.toLowerCase().includes(query)) ||
      post.languages?.some(l => l.toLowerCase().includes(query))
    );

    if (filtered.length === 0) {
      const li = document.createElement('li');
      li.className = 'text-zinc-400 text-sm px-2 py-3 text-center';
      li.textContent = 'No results found.';
      results.appendChild(li);
      return;
    }

    filtered.forEach(post => {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = post.url;
      a.className = 'flex flex-col gap-1 p-4 rounded-2xl border border-zinc-200 dark:border-zinc-700 hover:border-mint-400 dark:hover:border-mint-400 bg-white dark:bg-zinc-900 transition-all hover:scale-[1.01] block';

      const title = document.createElement('span');
      title.className = 'font-bold text-blacktext dark:text-mint-50 text-sm';
      title.textContent = post.title;

      const date = document.createElement('span');
      date.className = 'text-xs text-zinc-400';
      date.textContent = new Date(post.date).toLocaleDateString('en-US', {
        timeZone: 'UTC',
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      });

      a.appendChild(title);
      a.appendChild(date);
      li.appendChild(a);
      results.appendChild(li);
    });
  });
</script>

