---
import Social from "../ui/Social.astro";

const { items = [] }: { items: (keyof typeof menu)[] } = Astro.props as {
  items: (keyof typeof menu)[];
};

type SubDropdownItem = { name: string; path: string };
type DropdownItem = { name: string; path: string; subDropdown?: SubDropdownItem[] };
type MenuItem = { name: string; path: string; dropdown?: DropdownItem[] };

const menu: Record<string, MenuItem> = {
  about: { name: "About Me", path: "/about-me" },
  blog: {
    name: "Blog",
    path: "/blog/",
    dropdown: [
      { name: "All Posts", path: "/blog/posts/Blogger" },
    ]
  },
  writeups: {
    name: "Write-Ups",
    path: "/blog/writeups",
    dropdown: [
      {
        name: "Hackthebox",
        path: "/blog/posts/hackthebox",
        subDropdown: [
          { name: "Season 10", path: "/blog/posts/hackthebox/season10" }
        ]
      },
      { name: "Proving Grounds", path: "/blog/posts/provinggrounds/" }
    ]
  },
  home: { name: "Home", path: "/#home" },
  experience: { name: "Certifications", path: "/#experience" },
  projects: { name: "Projects", path: "/#projects" },
};

const baseClasses = {
  nav: "nav-links flex w-full justify-center gap-6 max-md:gap-3 max-md:py-6",
  link: "px-2 py-2 transition-all hover:text-mint-300 max-md:mx-auto max-md:w-full max-md:px-6 max-md:py-2",
  socialContainer: "flex items-center justify-center gap-5 md:hidden",
  dropdown: "relative group flex items-center max-md:flex-wrap max-md:w-full",
  dropdownMenu: "mobile-dropdown-menu absolute left-0 top-full hidden group-hover:block bg-white dark:bg-zinc-800 shadow-lg rounded-md py-2 min-w-[200px] z-50",
  dropdownItem: "block px-4 py-2 text-sm hover:bg-mint-100 dark:hover:bg-zinc-700 transition-colors dark:text-zinc-300 text-blacktext"
};
---

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const isHome = window.location.pathname === "/";

    const linkClasses = {
      active: ["text-mint-500","dark:text-mint-400", "font-bold", "[text-shadow:_1px_1px_11px_rgba(208,251,229,0.7)]"],
      inactive: ["dark:text-zinc-300", "text-blacktext"]
    };

    function toggleLinkClasses(link: Element, isActive: boolean) {
      if (isActive) {
        link.classList.add(...linkClasses.active);
        link.classList.remove(...linkClasses.inactive);
        link.setAttribute('aria-current', 'page');
      } else {
        link.classList.remove(...linkClasses.active);
        link.classList.add(...linkClasses.inactive);
        link.removeAttribute('aria-current');
      }
    }

    function updateActiveLink() {
      const currentPath = window.location.pathname;
      const currentHash = window.location.hash ? `#${window.location.hash.substring(1)}` : "";
      document.querySelectorAll("nav a").forEach((link) => {
        const path = link.getAttribute("data-path");
        toggleLinkClasses(link, path === currentPath || path === currentHash);
      });
    }

    function setupScrollSpy() {
      if (!isHome) return;
      const sections = document.querySelectorAll("section[id]");
      const navLinks = document.querySelectorAll("nav a");
      const observerOptions = {
        root: null,
        rootMargin: "-50% 0px",
        threshold: 0
      };
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const sectionId = entry.target.getAttribute("id");
            if (sectionId) {
              navLinks.forEach(link => {
                const path = link.getAttribute("data-path");
                toggleLinkClasses(link, path === `/#${sectionId}`);
              });
            }
          }
        });
      }, observerOptions);
      sections.forEach(section => observer.observe(section));
    }

    updateActiveLink();
    setupScrollSpy();
    window.addEventListener("hashchange", updateActiveLink);
  });
</script>

<nav class={baseClasses.nav} role="navigation" aria-label="Main Navigation">
  {items.map((key: string) => {
    const item = menu[key];
    if (!item) return null;

    if (item.dropdown) {
      return (
        <div class={baseClasses.dropdown}>
          <a
            href={item.path}
            class={`${baseClasses.link} max-md:flex-1`}
            data-path={item.path}
            aria-label={item.name}
            aria-current={item.path === Astro.url.pathname ? 'page' : undefined}
          >
            {item.name}
          </a>
          <button
            class="mobile-toggle md:hidden px-3 py-2 text-current flex-shrink-0"
            aria-label="Toggle menu"
          >
            <svg class="mobile-arrow transition-transform duration-200" width="14" height="14" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 5L7.5 10L12 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <div class={baseClasses.dropdownMenu}>
            {item.dropdown.map((dropdownItem: DropdownItem) => {
              if (dropdownItem.subDropdown) {
                return (
                  <div class="relative group/sub">
                    <a
                      href={dropdownItem.path}
                      class={`${baseClasses.dropdownItem} flex justify-between items-center gap-4`}
                      data-path={dropdownItem.path}
                    >
                      {dropdownItem.name}
                      <span class="hidden md:inline">
                        <svg width="10" height="10" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M6 11L10 7.5L6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                      </span>
                    </a>
                    <button
                      class="mobile-subtoggle md:hidden absolute right-2 top-1 px-2 py-1 text-current"
                      aria-label="Toggle submenu"
                    >
                      <svg class="mobile-arrow transition-transform duration-200" width="14" height="14" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 5L7.5 10L12 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>
                    <!-- Desktop submenu -->
                    <div class="desktop-subdropdown absolute left-full top-0 hidden group-hover/sub:block bg-white dark:bg-zinc-800 shadow-lg rounded-md py-2 min-w-[160px] z-50">
                      {dropdownItem.subDropdown.map((sub: SubDropdownItem) => (
                        <a href={sub.path} class={baseClasses.dropdownItem} data-path={sub.path}>
                          {sub.name}
                        </a>
                      ))}
                    </div>
                    <!-- Mobile submenu -->
                    <div class="mobile-subdropdown hidden md:hidden border-l-2 border-mint-400/30 ml-4 bg-white/5 dark:bg-white/5 py-1">
                      {dropdownItem.subDropdown.map((sub: SubDropdownItem) => (
                        <a href={sub.path} class={baseClasses.dropdownItem} data-path={sub.path}>
                          {sub.name}
                        </a>
                      ))}
                    </div>
                  </div>
                );
              }
              return (
                <a
                  href={dropdownItem.path}
                  class={baseClasses.dropdownItem}
                  data-path={dropdownItem.path}
                >
                  {dropdownItem.name}
                </a>
              );
            })}
          </div>
        </div>
      );
    }

    return (
      <a
        href={item.path}
        class={baseClasses.link}
        data-path={item.path}
        aria-label={item.name}
        aria-current={item.path === Astro.url.pathname ? 'page' : undefined}
      >
        {item.name}
      </a>
    );
  })}

  <div class={baseClasses.socialContainer} role="group" aria-label="Social Media Links">
    <Social link="https://www.google.com" iconName="github" />
    <Social link="https://www.linkedin.com/in/adrianreatva/" iconName="linkedin" />
  </div>
</nav>