---
import Layout from "../../../layouts/Layout.astro";
import Languages from "../../../components/blog/Languages.astro";
import Heading from "../../../components/ui/Heading.astro";

const pageTitle = "Technologies";
const allPostFiles = import.meta.glob("../posts/Blogger/*.md", { eager: true });
const allPosts = Object.values(allPostFiles);
const languages = [
    ...new Set(allPosts.map((post: any) => post.frontmatter.languages).flat()),
];
---



<Layout pageTitle={pageTitle}>
    <section class="py-8">
        <div class="flex flex-col gap-8 max-w-3xl mx-auto">
            <Heading text="Technologies" />
            <Languages variant="vertical" languages={languages} /> <!-- Fixed: Missing languages prop -->
        </div>
    </section>
</Layout>
