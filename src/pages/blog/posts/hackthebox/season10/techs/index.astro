---
import Layout from "../../../../../../layouts/Layout.astro";
import Languages from "../../../../../../components/blog/Languages_HTB.astro";
import Heading from "../../../../../../components/ui/Heading.astro";

const allPosts = await Astro.glob("../../season10/*.md");
const languages = [
    ...new Set(allPosts.map((post) => post.frontmatter.languages).flat()),
];
---

<Layout pageTitle="Technologies">
    <section class="py-8">
        <div class="flex flex-col gap-8 max-w-3xl mx-auto">
            <Heading text="Technologies" />
            <Languages variant="vertical" languages={languages} />
        </div>
    </section>
</Layout>